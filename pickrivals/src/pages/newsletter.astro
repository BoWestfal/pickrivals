---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Free Weekly AI Deals Newsletter"
  description="Join 1,000+ subscribers getting the best AI tool deals and SaaS discounts every week. Free forever."
>
  <Nav />

  <main class="relative z-10 max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">

    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-purple/10 border border-brand-purple/20 text-brand-purple-light text-xs font-semibold mb-6">
      📩 Free Newsletter
    </div>

    <h1 class="text-4xl sm:text-5xl font-extrabold text-text-primary mb-4">
      Get the Best AI Deals<br />Every Monday Morning
    </h1>

    <p class="text-text-secondary text-lg leading-relaxed mb-10">
      Join 1,000+ smart buyers. Every week: the top AI tool discounts, honest mini-reviews, and deals that actually save you money.
    </p>

    <!-- Beehiiv embed goes here -->
    <!-- After signing up at beehiiv.com, replace the form below with your embed code -->
    <div class="p-8 rounded-3xl bg-bg-surface border border-bg-border">
      <div class="flex flex-col gap-3 max-w-sm mx-auto">
        <input
          type="email"
          placeholder="your@email.com"
          class="px-4 py-3.5 rounded-xl bg-bg-base border border-bg-border text-text-primary placeholder-text-muted focus:outline-none focus:border-brand-purple/60 focus:ring-2 focus:ring-brand-purple/20 transition-all text-sm"
        />
        <button class="px-6 py-3.5 rounded-xl bg-gradient-to-r from-brand-purple to-brand-blue text-white font-bold text-sm hover:opacity-90 transition-opacity shadow-lg shadow-brand-purple/25">
          Subscribe for Free →
        </button>
      </div>
      <p class="text-text-muted text-xs mt-4">No spam. Unsubscribe anytime. Genuinely good deals only.</p>
    </div>

    <!-- What you get -->
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-4 text-left">
      {[
        { emoji: '🔥', title: 'Weekly Deals', desc: 'Hand-picked SaaS discounts every Monday' },
        { emoji: '⚡', title: 'Quick Reviews', desc: 'Honest takes on new AI tools, in 2 min' },
        { emoji: '💡', title: 'Pro Tips', desc: 'Workflows and prompts that save you time' },
      ].map(item => (
        <div class="p-4 rounded-2xl bg-bg-surface border border-bg-border">
          <div class="text-2xl mb-2">{item.emoji}</div>
          <h3 class="font-bold text-text-primary text-sm mb-1">{item.title}</h3>
          <p class="text-text-muted text-xs">{item.desc}</p>
        </div>
      ))}
    </div>

  </main>

  <Footer />
</Layout>
