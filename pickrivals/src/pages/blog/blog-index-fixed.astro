---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';

// In production, these come from Astro content collections (src/content/blog/)
const posts = [
  {
    slug: 'best-ai-writing-tools-2026',
    title: 'Best AI Writing Tools in 2026: Honest Review After Testing 12 Tools',
    excerpt: "We tested every major AI writing assistant so you don't have to. Here's what actually works for content creators, marketers, and solopreneurs.",
    category: 'Reviews',
    readTime: '8 min',
    publishedAt: 'March 25, 2026',
    tags: ['AI Writing', 'Jasper', 'Copy.ai', 'Review'],
  },
  {
    slug: 'chatgpt-vs-claude-2026',
    title: 'ChatGPT vs Claude in 2026: Which AI is Actually Better?',
    excerpt: 'After months of daily use, here\'s the honest breakdown of where each AI excels — and where it falls short. Spoiler: it depends on your use case.',
    category: 'Comparison',
    readTime: '12 min',
    publishedAt: 'March 18, 2026',
    tags: ['ChatGPT', 'Claude', 'AI Assistants'],
  },
  {
    slug: 'notion-ai-review-2026',
    title: 'Notion AI Review 2026: Is It Worth the Extra $10/Month?',
    excerpt: 'Notion\'s AI features have matured a lot. But is it better than using a dedicated AI writing tool? We break down every feature with real examples.',
    category: 'Review',
    readTime: '7 min',
    publishedAt: 'March 10, 2026',
    tags: ['Notion', 'Productivity', 'AI'],
  },
  {
    slug: 'surfer-seo-vs-clearscope',
    title: 'Surfer SEO vs Clearscope: Best Content Optimization Tool?',
    excerpt: 'Both promise to rank your content higher. But they work very differently. Here\'s a hands-on comparison with real ranking data.',
    category: 'Comparison',
    readTime: '10 min',
    publishedAt: 'March 3, 2026',
    tags: ['SEO', 'Content', 'Surfer', 'Clearscope'],
  },
];
---

<Layout
  title="AI Tool Reviews & Comparisons"
  description="In-depth reviews and comparisons of the best AI tools and SaaS software. No fluff, just honest takes."
>
  <Nav />

  <main class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-text-primary mb-4">Reviews & Guides</h1>
      <p class="text-text-secondary text-lg max-w-2xl">
        Honest, in-depth takes on AI tools and SaaS software. No sponsored fluff — just what actually works.
      </p>
    </div>

    <!-- Featured post -->
    <a
      href={`/blog/${posts[0].slug}`}
      class="group block mb-8 p-6 sm:p-8 rounded-3xl bg-bg-surface border border-bg-border hover:border-brand-purple/40 transition-all duration-300 hover:shadow-xl hover:shadow-brand-purple/5"
    >
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-3">
            <span class="px-2.5 py-1 rounded-full bg-brand-purple/10 border border-brand-purple/20 text-brand-purple-light text-xs font-semibold">
              {posts[0].category}
            </span>
            <span class="text-text-muted text-xs">⭐ Featured</span>
          </div>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-text-primary group-hover:text-brand-purple-light transition-colors mb-3">
            {posts[0].title}
          </h2>
          <p class="text-text-secondary leading-relaxed mb-4">{posts[0].excerpt}</p>
          <div class="flex items-center gap-4 text-xs text-text-muted">
            <span>{posts[0].publishedAt}</span>
            <span>·</span>
            <span>{posts[0].readTime} read</span>
          </div>
        </div>
        <div class="shrink-0">
          <span class="inline-flex items-center gap-1 text-brand-purple font-semibold text-sm group-hover:text-brand-purple-light transition-colors">
            Read article
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </div>
    </a>

    <!-- Post grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-20">
      {posts.slice(1).map(post => (
        <a
          href={`/blog/${post.slug}`}
          class="group flex flex-col p-5 rounded-2xl bg-bg-surface border border-bg-border hover:border-brand-purple/40 hover:shadow-lg hover:shadow-brand-purple/5 transition-all duration-200"
        >
          <div class="flex items-center gap-2 mb-3">
            <span class="px-2 py-0.5 rounded-full bg-bg-elevated text-text-muted text-xs font-medium">{post.category}</span>
          </div>
          <h3 class="font-bold text-text-primary group-hover:text-brand-purple-light transition-colors text-base leading-snug mb-2 flex-1">
            {post.title}
          </h3>
          <p class="text-text-muted text-sm leading-relaxed mb-4 line-clamp-2">{post.excerpt}</p>
          <div class="flex items-center justify-between text-xs text-text-muted mt-auto">
            <span>{post.publishedAt}</span>
            <span>{post.readTime} read</span>
          </div>
        </a>
      ))}
    </div>

    <NewsletterSignup />

  </main>

  <Footer />
</Layout>
