---
// Replace YOUR_BEEHIIV_PUBLICATION_ID with your actual Beehiiv pub ID after signup
// Get it from: app.beehiiv.com → Settings → Publication → Embed
const BEEHIIV_PUB_ID = 'YOUR_BEEHIIV_PUBLICATION_ID';
---

<section class="relative rounded-3xl overflow-hidden border border-brand-purple/20 bg-gradient-to-br from-brand-purple/10 via-bg-elevated to-brand-blue/10 p-8 sm:p-12">
  <!-- Decorative blobs -->
  <div class="absolute -top-10 -right-10 w-40 h-40 bg-brand-purple/20 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-brand-blue/20 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-2xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-purple/20 border border-brand-purple/30 text-brand-purple-light text-xs font-semibold mb-4">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22,6 12,13 2,6"/>
      </svg>
      Weekly Newsletter
    </div>

    <h2 class="text-3xl sm:text-4xl font-extrabold text-text-primary mb-3">
      Never Miss a Deal Again
    </h2>
    <p class="text-text-secondary text-lg mb-8 leading-relaxed">
      Every week: the best AI tool discounts, honest tool reviews, and hidden SaaS gems — straight to your inbox. Free forever.
    </p>

    <!-- Beehiiv embed - replace with your actual embed code from Beehiiv dashboard -->
    <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input
        type="email"
        placeholder="your@email.com"
        class="flex-1 px-4 py-3 rounded-xl bg-bg-base border border-bg-border text-text-primary placeholder-text-muted focus:outline-none focus:border-brand-purple/60 focus:ring-2 focus:ring-brand-purple/20 transition-all text-sm"
      />
      <button
        class="px-6 py-3 rounded-xl bg-gradient-to-r from-brand-purple to-brand-blue text-white font-semibold text-sm hover:opacity-90 transition-opacity whitespace-nowrap shadow-lg shadow-brand-purple/25"
      >
        Get Free Deals →
      </button>
    </div>

    <p class="mt-3 text-text-muted text-xs">
      Join 1,000+ smart buyers. Unsubscribe anytime.
    </p>
  </div>

  <!-- TODO: Replace the form above with your Beehiiv embed once you create your account at beehiiv.com -->
  <!-- Example Beehiiv embed:
  <iframe src="https://embeds.beehiiv.com/YOUR_ID" width="100%" frameborder="0" scrolling="no" style="border-radius: 4px; overflow: hidden;"></iframe>
  -->
</section>
