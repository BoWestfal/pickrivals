---
export interface Props {
  name: string;
  tagline: string;
  discount: string;
  originalPrice?: string;
  dealPrice: string;
  category: string;
  badge?: string;
  affiliateUrl: string;
  logo?: string;
  expiresAt?: string;
  isHot?: boolean;
}

const {
  name,
  tagline,
  discount,
  originalPrice,
  dealPrice,
  category,
  badge,
  affiliateUrl,
  logo,
  expiresAt,
  isHot = false,
} = Astro.props;
---

<article class="group relative flex flex-col bg-bg-surface border border-bg-border rounded-2xl overflow-hidden hover:border-brand-purple/40 transition-all duration-300 hover:shadow-xl hover:shadow-brand-purple/10">

  <!-- Hot badge -->
  {isHot && (
    <div class="absolute top-3 right-3 z-10 px-2 py-1 bg-gradient-to-r from-orange-500 to-red-500 text-white text-xs font-bold rounded-full animate-pulse-slow">
      🔥 HOT
    </div>
  )}

  <!-- Discount badge -->
  <div class="absolute top-3 left-3 z-10 px-2.5 py-1 bg-brand-purple/20 border border-brand-purple/30 text-brand-purple-light text-xs font-bold rounded-full">
    {discount} OFF
  </div>

  <!-- Card header -->
  <div class="pt-10 px-5 pb-4">
    <div class="flex items-center gap-3 mb-3">
      {logo ? (
        <img src={logo} alt={name} class="w-10 h-10 rounded-xl object-cover" />
      ) : (
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-purple/30 to-brand-blue/30 flex items-center justify-center text-lg font-bold text-brand-purple-light border border-brand-purple/20">
          {name.charAt(0)}
        </div>
      )}
      <div>
        <h3 class="font-bold text-text-primary text-base group-hover:text-brand-purple-light transition-colors">{name}</h3>
        <span class="text-xs text-text-muted bg-bg-elevated px-2 py-0.5 rounded-full">{category}</span>
      </div>
    </div>
    <p class="text-text-secondary text-sm leading-relaxed">{tagline}</p>
  </div>

  <!-- Price -->
  <div class="px-5 pb-4 flex items-baseline gap-2">
    <span class="text-2xl font-extrabold text-text-primary">{dealPrice}</span>
    {originalPrice && (
      <span class="text-text-muted text-sm line-through">{originalPrice}</span>
    )}
    {badge && (
      <span class="ml-auto text-xs text-brand-teal font-medium">{badge}</span>
    )}
  </div>

  <!-- Expiry -->
  {expiresAt && (
    <div class="px-5 pb-3">
      <p class="text-xs text-text-muted flex items-center gap-1.5">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        Expires {expiresAt}
      </p>
    </div>
  )}

  <!-- CTA -->
  <div class="mt-auto px-5 pb-5">
    <a
      href={affiliateUrl}
      target="_blank"
      rel="noopener noreferrer nofollow"
      class="w-full flex items-center justify-center gap-2 py-2.5 rounded-xl bg-gradient-to-r from-brand-purple to-brand-blue text-white text-sm font-semibold hover:opacity-90 transition-opacity shadow-lg shadow-brand-purple/20"
    >
      Grab This Deal
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>
