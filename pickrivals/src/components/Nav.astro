---
const navLinks = [
  { href: '/compare', label: 'Compare' },
  { href: '/deals', label: 'Deals 🔥' },
  { href: '/blog', label: 'Reviews' },
  { href: '/alternatives', label: 'Alternatives' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-bg-border/60 bg-bg-base/80 backdrop-blur-xl">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-purple to-brand-blue flex items-center justify-center shadow-lg shadow-brand-purple/25 group-hover:shadow-brand-purple/40 transition-shadow">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8L7 12L13 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="font-bold text-lg text-text-primary tracking-tight">
          Pick<span class="text-brand-purple">Rivals</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-1.5 rounded-lg text-sm font-medium transition-colors',
              currentPath.startsWith(link.href)
                ? 'bg-brand-purple/10 text-brand-purple-light'
                : 'text-text-secondary hover:text-text-primary hover:bg-bg-elevated'
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="flex items-center gap-3">
        <a
          href="/newsletter"
          class="hidden sm:flex items-center gap-2 px-4 py-2 rounded-lg bg-gradient-to-r from-brand-purple to-brand-blue text-white text-sm font-semibold hover:opacity-90 transition-opacity shadow-lg shadow-brand-purple/25"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          Get Deals
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-bg-elevated transition-colors"
          aria-label="Open menu"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-bg-border/40 mt-1 pt-3">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-bg-elevated transition-colors mb-1"
        >
          {link.label}
        </a>
      ))}
      <a href="/newsletter" class="block mt-2 px-3 py-2.5 rounded-lg bg-gradient-to-r from-brand-purple to-brand-blue text-white text-sm font-semibold text-center">
        Get Weekly Deals →
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
