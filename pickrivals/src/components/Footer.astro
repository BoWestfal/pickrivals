---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-bg-border/60 bg-bg-surface mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-10">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-3">
          <div class="w-7 h-7 rounded-md bg-gradient-to-br from-brand-purple to-brand-blue flex items-center justify-center">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
              <path d="M3 8L7 12L13 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="font-bold text-text-primary">Pick<span class="text-brand-purple">Rivals</span></span>
        </a>
        <p class="text-text-muted text-sm leading-relaxed">
          Honest AI tool comparisons and exclusive SaaS deals to help you work smarter.
        </p>
      </div>

      <!-- Compare -->
      <div>
        <h4 class="text-text-primary font-semibold text-sm mb-3">Compare</h4>
        <ul class="space-y-2">
          <li><a href="/compare/chatgpt-vs-claude" class="text-text-muted text-sm hover:text-brand-purple transition-colors">ChatGPT vs Claude</a></li>
          <li><a href="/compare/notion-vs-obsidian" class="text-text-muted text-sm hover:text-brand-purple transition-colors">Notion vs Obsidian</a></li>
          <li><a href="/compare/midjourney-vs-dalle" class="text-text-muted text-sm hover:text-brand-purple transition-colors">Midjourney vs DALL·E</a></li>
          <li><a href="/compare" class="text-brand-purple text-sm hover:text-brand-purple-light transition-colors">All comparisons →</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-text-primary font-semibold text-sm mb-3">Resources</h4>
        <ul class="space-y-2">
          <li><a href="/deals" class="text-text-muted text-sm hover:text-brand-purple transition-colors">Current Deals</a></li>
          <li><a href="/blog" class="text-text-muted text-sm hover:text-brand-purple transition-colors">Reviews & Guides</a></li>
          <li><a href="/alternatives" class="text-text-muted text-sm hover:text-brand-purple transition-colors">Alternatives</a></li>
          <li><a href="/newsletter" class="text-text-muted text-sm hover:text-brand-purple transition-colors">Newsletter</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-text-primary font-semibold text-sm mb-3">Legal</h4>
        <ul class="space-y-2">
          <li><a href="/privacy" class="text-text-muted text-sm hover:text-brand-purple transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-text-muted text-sm hover:text-brand-purple transition-colors">Terms of Use</a></li>
          <li><a href="/affiliate-disclosure" class="text-text-muted text-sm hover:text-brand-purple transition-colors">Affiliate Disclosure</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-bg-border/40 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-text-muted text-xs">
        © {currentYear} PickRivals. Some links are affiliate links — we may earn a commission at no extra cost to you.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://twitter.com/pickrivals" class="text-text-muted hover:text-brand-purple transition-colors" aria-label="Twitter">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
